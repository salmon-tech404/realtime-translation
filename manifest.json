{
  "manifest_version": 3,
  "name": "Realtime Translation (Google Meet)",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "version": "1.0.0",
  "description": "Real-time translation for Google Meet",

  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "sidePanel",
    "tabCapture"
  ],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://api.openai.com/*",
    "https://api.deepseek.com/*",
    "https://api.anthropic.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["src/content.js"],
      "css": ["src/css/content.css"]
    },
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["src/capture/captions.js"]
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Realtime Translation"
  },
  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "popup.html"
  }
}
